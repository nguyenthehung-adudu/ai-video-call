'use client';

import { ReactNode, useEffect, useState } from 'react';
import { useUser } from '@clerk/nextjs';
import { StreamChat } from 'stream-chat';
import { Chat } from 'stream-chat-react';
import { generateChatToken, upsertStreamChatUser } from '@/actions/stream.actions';

const API_KEY = process.env.NEXT_PUBLIC_STREAM_API_KEY!;

let chatClient: StreamChat | null = null;

function getChatClient(): StreamChat {
  if (!chatClient) {
    chatClient = StreamChat.getInstance(API_KEY);
  }
  return chatClient;
}

type ClerkUserFields = {
  id: string;
  fullName?: string | null;
  firstName?: string | null;
  lastName?: string | null;
  username?: string | null;
  imageUrl?: string | null;
  primaryEmailAddress?: { emailAddress: string } | null;
};

/** Real display name — never the raw Clerk id. */
function clerkDisplayName(user: ClerkUserFields): string {
  const full = user.fullName?.trim();
  if (full) return full;

  const fromParts = [user.firstName, user.lastName].filter(Boolean).join(' ').trim();
  if (fromParts) return fromParts;

  if (user.username?.trim()) return user.username.trim();

  const email = user.primaryEmailAddress?.emailAddress;
  if (email) return email;

  return 'User';
}

/**
 * Avatar must always be a non-empty URL Stream can load (MessageList uses message.user.image).
 * Seed uses fullName as requested; if empty, falls back to display name.
 */
function streamChatImage(user: ClerkUserFields): string {
  const direct = user.imageUrl?.trim();
  if (direct) return direct;

  const seed =
    (user.fullName?.trim() && user.fullName.trim()) || clerkDisplayName(user);
  return `https://api.dicebear.com/7.x/initials/svg?seed=${encodeURIComponent(seed)}`;
}

const ChatProvider = ({ children }: { children: ReactNode }) => {
  const { user, isLoaded } = useUser();
  const [client, setClient] = useState<StreamChat | null>(null);
  const [connecting, setConnecting] = useState(true);

  useEffect(() => {
    if (!isLoaded) return;

    if (!user?.id) {
      setClient(null);
      setConnecting(false);
      return;
    }

    let cancelled = false;
    const streamUser = getChatClient();

    const connect = async () => {
      const nameForStream =
        user.fullName?.trim() || clerkDisplayName(user);
      const image = streamChatImage(user);

      if (streamUser.userID === user.id) {
        try {
          await upsertStreamChatUser(user.id, nameForStream, image);
        } catch (e) {
          console.error('❌ CHAT upsert failed:', e);
        }
        if (!cancelled) {
          setClient(streamUser);
          setConnecting(false);
        }
        return;
      }

      setConnecting(true);

      try {
        if (streamUser.userID) {
          await streamUser.disconnectUser();
        }

        console.log('CONNECT USER:', user.id, nameForStream);

        const token = await generateChatToken(user.id, nameForStream, image);

        await streamUser.connectUser(
          {
            id: user.id,
            name: nameForStream,
            image,
          },
          token,
        );

        if (!cancelled) setClient(streamUser);
      } catch (err) {
        console.error('❌ CHAT connectUser failed:', err);
        if (!cancelled) setClient(null);
      } finally {
        if (!cancelled) setConnecting(false);
      }
    };

    void connect();

    return () => {
      cancelled = true;
      void streamUser.disconnectUser().catch(() => undefined);
      setClient(null);
    };
  }, [
    isLoaded,
    user?.id,
    user?.fullName,
    user?.firstName,
    user?.lastName,
    user?.username,
    user?.imageUrl,
    user?.primaryEmailAddress?.emailAddress,
  ]);

  if (!isLoaded || connecting || !client) {
    return (
      <div className="text-white flex h-screen items-center justify-center">
        💬 {connecting ? 'Connecting chat…' : 'Chat unavailable'}
        {user?.id ? ` (${user.id})` : ''}
      </div>
    );
  }

  return <Chat client={client}>{children}</Chat>;
};

export default ChatProvider;
