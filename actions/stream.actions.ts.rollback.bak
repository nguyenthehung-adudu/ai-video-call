'use server';

import { StreamClient } from '@stream-io/node-sdk';
import { StreamChat } from 'stream-chat';

const API_KEY = process.env.NEXT_PUBLIC_STREAM_API_KEY!;
const API_SECRET = process.env.STREAM_SECRET_KEY!;

// 🎥 VIDEO TOKEN
export const tokenProvider = async (userId: string) => {
  if (!userId) throw new Error('Missing userId');

  const client = new StreamClient(API_KEY, API_SECRET);

  const token = client.createToken(userId);

  return token;
};

const avatarFallback = (seed: string) =>
  `https://api.dicebear.com/7.x/initials/svg?seed=${encodeURIComponent(seed || 'User')}`;

function getServerChatClient() {
  return StreamChat.getInstance(API_KEY, API_SECRET);
}

/**
 * Stream Chat JS SDK exposes batch upsertUsers; this wraps a single user (same as upsertUser).
 * Chat user store is separate from Video — always use Stream Chat server client here.
 */
export async function upsertStreamChatUser(
  userId: string,
  name: string,
  image?: string | null,
) {
  if (!userId) throw new Error('Missing userId');

  let displayName = (name || '').trim() || 'User';
  if (displayName === userId) {
    displayName = 'User';
  }

  const imageUrl = (image?.trim() || avatarFallback(displayName)) as string;

  const serverClient = getServerChatClient();
  await serverClient.upsertUsers([
    {
      id: userId,
      name: displayName,
      image: imageUrl,
    },
  ]);
}

export const generateChatToken = async (
  userId: string,
  name: string,
  image?: string | null,
) => {
  if (!userId) throw new Error('Missing userId');

  await upsertStreamChatUser(userId, name, image);
  return getServerChatClient().createToken(userId);
};

export const ensureMeetingChatChannel = async (
  meetingId: string,
  memberIds: string[],
) => {
  if (!meetingId) throw new Error('Missing meetingId');

  const members = Array.from(new Set(memberIds.filter(Boolean)));
  if (!members.length) throw new Error('Missing channel members');

  const serverClient = getServerChatClient();

  const channelId = `meeting-${meetingId}`;
  const channel = serverClient.channel('messaging', channelId);

  try {
    const response = await channel.query();
    const existingMembers = Object.keys(response.members ?? {});
    const missingMembers = members.filter((id) => !existingMembers.includes(id));

    if (missingMembers.length) {
      await channel.addMembers(missingMembers);
    }
  } catch {
    const createdById = members[0];
    const newChannel = serverClient.channel('messaging', channelId, {
      members,
      created_by_id: createdById,
    });
    await newChannel.create();
  }
};
